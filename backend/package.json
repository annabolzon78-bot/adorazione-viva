{
  "name": "adorazione-viva-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=../database/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=../database/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=../database/prisma/schema.prisma",
    "db:seed": "tsx ../database/prisma/seeds/seed.ts",
    "db:studio": "prisma studio --schema=../database/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=../database/prisma/schema.prisma --force",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.16.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}