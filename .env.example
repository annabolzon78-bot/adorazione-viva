# ============================================================
# ADORAZIONE VIVA — Variabili di configurazione
# Copia questo file in .env e compila i valori reali
# ⚠️  Non committare mai il file .env su GitHub
# ============================================================

# ── SUPABASE (FRONTEND) ───────────────────────────────────────
# Ottenibili da: supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ── SUPABASE (BACKEND — solo nel backend, mai nel frontend) ──
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── DATABASE (solo per backend Express / microservizi) ───────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── BACKEND (se usi il microservizio Express) ─────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
BCRYPT_ROUNDS=12

# ── APP ───────────────────────────────────────────────────────
VITE_APP_NAME=Adorazione Viva
VITE_APP_URL=https://adorazioneviva.com

# ── EMAIL (opzionale — Supabase gestisce email auth di default) 
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@adorazioneviva.com
